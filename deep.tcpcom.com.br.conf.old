# ============================================================================
# Apache Vhost Configuration for deep.tcpcom.com.br
# Reverse Proxy: Frontend (3101) + Backend API (8101)
# ============================================================================

# HTTP Virtual Host
<VirtualHost *:80>
    ServerName deep.tcpcom.com.br
    ServerAlias www.deep.tcpcom.com.br

    DocumentRoot /var/www/deepagents/deepagent_jp

    RewriteEngine on
    RewriteCond %{SERVER_NAME} =deep.tcpcom.com.br [OR]
    RewriteCond %{SERVER_NAME} =www.deep.tcpcom.com.br
    RewriteRule ^ https://%{SERVER_NAME}%{REQUEST_URI} [END,NE,R=permanent]
</VirtualHost>

# ============================================================================
# HTTPS Virtual Host (Primary) - SSL será configurado via certbot --apache
# ============================================================================
<VirtualHost *:443>
    ServerName deep.tcpcom.com.br
    ServerAlias www.deep.tcpcom.com.br

    DocumentRoot /var/www/deepagents/deepagent_jp

    # ========================================================================
    # Security Headers
    # ========================================================================
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline';"

    # ========================================================================
    # Logging
    # ========================================================================
    ErrorLog /var/log/apache2/deep.tcpcom.com.br-error.log
    CustomLog /var/log/apache2/deep.tcpcom.com.br-access.log combined

    # ========================================================================
    # Reverse Proxy Configuration
    # ========================================================================

    # Enable Proxy
    <IfModule mod_proxy.c>
        ProxyRequests Off
        ProxyPreserveHost On

        # WebSocket support para backend streaming routes
        <IfModule mod_proxy_wstunnel.c>
            RewriteEngine On
            RewriteCond %{HTTP:Upgrade} websocket [NC]
            RewriteCond %{HTTP:Connection} upgrade [NC]
            RewriteRule ^/threads/(.*)/runs/stream$ ws://localhost:8101/threads/$1/runs/stream [P,L]
        </IfModule>

        # Next.js App Routes (/api/*) -> Frontend (proxy interno para backend)        ProxyPass /api http://localhost:3101/api nocanon
        ProxyPassReverse /api http://localhost:3101/api

        # Backend endpoints (explícitos)
        ProxyPass /auth http://localhost:8101/auth nocanon
        ProxyPassReverse /auth http://localhost:8101/auth

        ProxyPass /health http://localhost:8101/health nocanon
        ProxyPassReverse /health http://localhost:8101/health

        # Frontend (Next.js) - todos os demais paths
        ProxyPass / http://localhost:3101/ nocanon
        ProxyPassReverse / http://localhost:3101/
    </IfModule>

    # ========================================================================
    # Proxy Settings
    # ========================================================================
    <IfModule mod_proxy.c>
        RequestHeader set X-Forwarded-For "%{REMOTE_ADDR}s"
        RequestHeader set X-Forwarded-Proto "https"
        RequestHeader set X-Forwarded-Host "%{HTTP_HOST}s"
        RequestHeader set X-Real-IP "%{REMOTE_ADDR}s"
    </IfModule>

    # ========================================================================
    # Static Files
    # ========================================================================
    <Directory /var/www/deepagents/deepagent_jp>
        Require all granted
        Options -Indexes +FollowSymLinks
        AllowOverride All
    </Directory>

SSLCertificateFile /etc/letsencrypt/live/deep.tcpcom.com.br/fullchain.pem
SSLCertificateKeyFile /etc/letsencrypt/live/deep.tcpcom.com.br/privkey.pem
Include /etc/letsencrypt/options-ssl-apache.conf
</VirtualHost>

